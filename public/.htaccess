Options -MultiViews
DirectoryIndex index.html
ErrorDocument 404 /ro/404/index.html

<IfModule mod_rewrite.c>
RewriteEngine On

# Canonical host and protocol.
RewriteCond %{HTTPS} !=on [OR]
RewriteCond %{HTTP_HOST} ^www\.autoterra\.md$ [NC]
RewriteRule ^ https://autoterra.md%{REQUEST_URI} [R=301,L,NE]

# Canonical default locale at the site root.
RewriteRule ^$ /ro/ [R=301,L]

# Keep localized HTML routes on a single trailing-slash format.
RewriteCond %{REQUEST_URI} !/$
RewriteCond %{REQUEST_URI} ^/(ro|ru|en)(?:/.*)?$
RewriteCond %{REQUEST_URI} !\.[^./]+$
RewriteRule ^(.+)$ /$1/ [R=301,L]

# Existing files and prerendered directories are served as-is.
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]
</IfModule>
